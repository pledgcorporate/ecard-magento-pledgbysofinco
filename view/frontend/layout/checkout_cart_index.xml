<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="1column" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="checkout.cart.totals.container">
            <block class="Pledg\PledgPaymentGateway\Block\Product\Widget"
                template="Pledg_PledgPaymentGateway::widget/container.phtml"
                name="checkout.cart.pledgwidget"
                before="checkout.cart.totals">
                <arguments>
                    <argument name="widgetType" xsi:type="string">cart</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
